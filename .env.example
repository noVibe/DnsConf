# GitHub Environment variables (non-secret)
DNS=NEXTDNS
BLOCK=https://raw.githubusercontent.com/Internet-Helper/GeoHideDNS/refs/heads/main/hosts/hosts
REDIRECT=https://raw.githubusercontent.com/Internet-Helper/GeoHideDNS/refs/heads/main/hosts/hosts
NEXTDNS_REWRITE_EXCLUSIONS={"patterns":["*.instagram.com","*.facebook.com"]}

# GitHub Environment secrets (only needed when running against a real NextDNS profile)
CLIENT_ID=replace-with-nextdns-profile-id
AUTH_SECRET=replace-with-nextdns-api-key

# Local Docker apply flow:
# cp .env.example .env.local
# docker compose --profile apply run --rm apply
